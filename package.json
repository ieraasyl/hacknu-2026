{
  "name": "hacknu-2026",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "bun run build && vite preview",
    "test": "vitest run",
    "auth:generate": "bunx auth generate --config ./src/lib/auth.ts --output src/db/auth-schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:studio:local": "drizzle-kit studio --config drizzle.config.local.ts",
    "db:studio:remote": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply hacknu-2026-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hacknu-2026-db --remote",
    "types": "wrangler types",
    "deploy": "bun install && bun run build && wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.9.9",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/workers-types": "^4.20260305.1",
    "@eslint/js": "^10.0.1",
    "@tanstack/devtools-vite": "^0.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.70.0"
  }
}
